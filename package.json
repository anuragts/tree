{
	"name": "tree-agent",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.12",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"bin": {
		"tree-agent": "apps/tree-cli/dist/index.js"
	},
	"scripts": {
		"dev": "bun apps/tree-cli/src/index.ts",
		"start": "node apps/tree-cli/dist/index.js",
		"build": "tsc -b",
		"check": "tsc -b --pretty false",
		"test": "bun test",
		"lint": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@types/node": "^24.0.0",
		"typescript": "^5.9.2"
	},
	"dependencies": {
		"@earendil-works/pi-tui": "^0.74.0",
		"chalk": "^5.5.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
